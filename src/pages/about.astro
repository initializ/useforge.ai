---
import fs from 'node:fs';
import path from 'node:path';
import Base from '@/layouts/Base.astro';

interface Contributor {
  login: string;
  avatar_url: string;
  html_url: string;
  contributions: number;
}

let contributors: Contributor[] = [];
try {
  const filePath = path.resolve('src/data/contributors.json');
  if (fs.existsSync(filePath)) {
    const data = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    if (Array.isArray(data)) {
      contributors = data;
    } else if (data?.contributors) {
      contributors = data.contributors;
    }
  }
} catch {
  // contributors.json doesn't exist yet
}

const principles = [
  {
    title: 'SKILL.md is the hero',
    description: 'A portable, language-agnostic skill format. One file defines what your agent can do — readable by humans and machines.',
  },
  {
    title: 'Secure by default',
    description: 'Egress enforcement, runtime sandboxing, encrypted secrets, and build signing are built in — not bolted on.',
  },
  {
    title: 'Progressive disclosure',
    description: 'Start simple with a SKILL.md and grow into multi-agent orchestration. Complexity is opt-in.',
  },
  {
    title: 'No lock-in',
    description: 'Multi-provider LLM support, standard formats, and portable deployments. Your agents run anywhere.',
  },
  {
    title: 'Metadata-driven',
    description: 'Configuration over code. Agent behavior is declared in forge.yaml and SKILL.md frontmatter, not hidden in source files.',
  },
  {
    title: 'Trust is computed',
    description: 'Every skill is automatically scanned, analyzed, and assigned a trust level. No manual curation required.',
  },
  {
    title: 'Drop-in extensibility',
    description: 'Add new providers, tools, and skills without forking. The plugin architecture is designed for composition.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Forge',
  description: 'Forge is an open-source framework for building, deploying, and operating AI agents with built-in security and observability.',
  url: 'https://useforge.ai/about',
  publisher: {
    '@type': 'Organization',
    name: 'Initializ',
    url: 'https://initializ.ai',
  },
};
---

<Base
  title="About — Forge"
  description="Forge is an open-source framework for building, deploying, and operating AI agents with built-in security and observability."
  layout="marketing"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-12 sm:pt-28 sm:pb-16">
    <div
      class="pointer-events-none absolute inset-0 -top-40"
      style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(249,115,22,0.10) 0%, transparent 70%)"
    ></div>
    <div class="relative mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-forge-orange to-forge-amber bg-clip-text text-transparent">
          About Forge
        </span>
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto">
        Making AI agents safe for production. Open source, security-first, built for the real world.
      </p>
    </div>
  </section>

  <!-- Origin story -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">Why Forge exists</h2>
      <div class="space-y-4 text-gray-400 leading-relaxed">
        <p>
          AI agents are moving from demos to production. But the infrastructure to run them safely
          doesn't exist yet. Most frameworks optimize for getting started fast — open ports, arbitrary
          code execution, no isolation. That works for prototypes. It doesn't work inside a regulated
          organization.
        </p>
        <p>
          Forge was built to close that gap. It provides the runtime layer that agents need in
          production: egress enforcement, encrypted secrets, build signing, structured audit logging,
          and a portable skill format that works across local, cloud, VPC, and air-gapped environments.
        </p>
        <p>
          We believe agent infrastructure should be open. Not because open source is fashionable,
          but because security infrastructure that can't be audited can't be trusted.
        </p>
      </div>
    </div>
  </section>

  <!-- Initializ stewardship -->
  <section class="py-16 sm:py-20 border-t border-dark-border">
    <div class="mx-auto max-w-3xl px-4">
      <div class="bg-dark-surface border border-dark-border rounded-forge-xl p-8">
        <h2 class="text-xl font-bold text-white mb-4">Built by Initializ</h2>
        <p class="text-gray-400 leading-relaxed">
          Forge is built and maintained by
          <a href="https://initializ.ai" target="_blank" rel="noopener" class="text-forge-orange hover:text-forge-amber transition-colors">Initializ</a>,
          a team focused on making AI agents safe for production. We believe the best way to do that
          is in the open — with transparent security primitives, auditable trust models, and a
          community that holds the bar high.
        </p>
      </div>
    </div>
  </section>

  <!-- Design principles -->
  <section class="py-16 sm:py-20 border-t border-dark-border">
    <div class="mx-auto max-w-5xl px-4">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Design Principles</h2>
        <p class="text-gray-400 max-w-2xl mx-auto">
          Seven principles that guide every decision in Forge.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {principles.map((p, i) => (
          <div class="bg-dark-surface border border-dark-border rounded-forge-lg p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="flex items-center justify-center w-7 h-7 rounded-full bg-forge-orange/10 text-forge-orange text-sm font-bold">
                {i + 1}
              </span>
              <h3 class="font-bold text-white text-sm">{p.title}</h3>
            </div>
            <p class="text-sm text-gray-400 leading-relaxed">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contributors -->
  <section class="py-16 sm:py-20 border-t border-dark-border">
    <div class="mx-auto max-w-5xl px-4 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Contributors</h2>
      <p class="text-gray-400 mb-10 max-w-xl mx-auto">
        Forge is open source and built by the community. Every contribution matters.
      </p>

      {contributors.length > 0 ? (
        <>
          <div class="flex flex-wrap justify-center gap-4 mb-6">
            {contributors.slice(0, 30).map((c) => (
              <a
                href={c.html_url}
                target="_blank"
                rel="noopener"
                title={`${c.login} (${c.contributions} contributions)`}
                class="group flex flex-col items-center gap-1.5"
              >
                <img
                  src={c.avatar_url}
                  alt={c.login}
                  class="w-12 h-12 rounded-full border-2 border-dark-border group-hover:border-forge-orange transition-colors"
                  loading="lazy"
                />
                <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">
                  {c.login}
                </span>
              </a>
            ))}
          </div>
          <p class="text-sm text-gray-500 mb-8">
            {contributors.length} contributor{contributors.length !== 1 ? 's' : ''} and counting
          </p>
        </>
      ) : (
        <div class="bg-dark-surface border border-dark-border rounded-forge-lg p-8 max-w-md mx-auto mb-8">
          <p class="text-gray-400 mb-2">Be the first contributor</p>
          <p class="text-sm text-gray-500">
            Forge is just getting started. Help shape the future of agent development.
          </p>
        </div>
      )}

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://github.com/initializ/forge"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-2.5 border border-dark-border hover:border-gray-500 text-gray-300 hover:text-white text-sm font-medium rounded-forge-md transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          Contribute on GitHub
        </a>
        <a
          href="https://github.com/initializ/forge/blob/main/CONTRIBUTING.md"
          target="_blank"
          rel="noopener"
          class="text-sm text-gray-400 hover:text-white transition-colors"
        >
          Contributing Guide
        </a>
        <a
          href="https://github.com/initializ/forge/blob/main/CODE_OF_CONDUCT.md"
          target="_blank"
          rel="noopener"
          class="text-sm text-gray-400 hover:text-white transition-colors"
        >
          Code of Conduct
        </a>
        <a
          href="https://github.com/initializ/forge/blob/main/LICENSE"
          target="_blank"
          rel="noopener"
          class="text-sm text-gray-400 hover:text-white transition-colors"
        >
          Apache 2.0 License
        </a>
      </div>
    </div>
  </section>
</Base>
