---
import Base from '@/layouts/Base.astro';

const metaDescription =
  'Upcoming events, talks, and workshops from the Forge team. Register, add to your calendar, or invite us to your event.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Events',
  description: metaDescription,
  url: 'https://useforge.ai/events/',
  publisher: {
    '@type': 'Organization',
    name: 'Initializ',
    url: 'https://initializ.ai',
  },
};
---

<Base
  title="Events — Forge"
  description={metaDescription}
  layout="marketing"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-12 sm:pt-28 sm:pb-16">
    <div
      class="pointer-events-none absolute inset-0 -top-40"
      style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(249,115,22,0.10) 0%, transparent 70%)"
    ></div>
    <div class="relative mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-forge-orange to-forge-amber bg-clip-text text-transparent">
          Events
        </span>
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-secondary max-w-2xl mx-auto">
        Where to find the Forge team — talks, workshops, meetups, and conferences. Register
        below, add to your calendar, or invite us to your event.
      </p>
    </div>
  </section>

  <!-- Upcoming -->
  <section class="py-12 border-t border-dark-border">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="text-2xl sm:text-3xl font-bold text-heading mb-6 text-center">Upcoming</h2>

      <div class="mx-auto w-full max-w-2xl rounded-forge-lg overflow-hidden border border-dark-border bg-dark-surface">
        <iframe
          src="https://luma.com/embed/event/evt-9ZnGnQtifJKOHd3/simple"
          width="100%"
          height="450"
          frameborder="0"
          style="border: 0; min-height: 450px; display: block;"
          allow="fullscreen; payment"
          aria-label="Upcoming event — register on Luma"
          tabindex="0"
        ></iframe>
      </div>
      <p class="mt-4 text-sm text-muted text-center">
        Trouble loading the embed?
        <a
          href="https://luma.com/evt-9ZnGnQtifJKOHd3"
          target="_blank"
          rel="noopener"
          class="text-forge-orange hover:text-forge-amber transition-colors"
        >
          Open on Luma →
        </a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 border-t border-dark-border">
    <div class="mx-auto max-w-3xl px-4">
      <div class="bg-dark-surface border border-dark-border rounded-forge-xl p-8 text-center">
        <h2 class="text-xl font-bold text-heading mb-2">Want us at your event?</h2>
        <p class="text-secondary text-sm mb-5">
          Conferences, meetups, podcasts, workshops — drop us a line and we'll find a way to be
          there.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="mailto:hello@initializ.ai?subject=Invite%20Forge%20to%20speak%20at%20our%20event"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-forge-orange hover:bg-forge-deep text-white text-sm font-medium rounded-forge-md transition-colors"
          >
            Invite Forge
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="https://discord.gg/PtFa4z97Ag"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-2.5 border border-dark-border hover:border-gray-500 text-body hover:text-heading text-sm font-medium rounded-forge-md transition-colors"
          >
            Stay in the loop on Discord
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
