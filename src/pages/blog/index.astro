---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Forge Blog',
  description: 'Tutorials, deep dives, and updates from the Forge team.',
  url: 'https://useforge.ai/blog',
  publisher: {
    '@type': 'Organization',
    name: 'Initializ',
    url: 'https://initializ.ai',
  },
};
---

<Base
  title="Blog — Forge"
  description="Tutorials, deep dives, and updates from the Forge team."
  layout="marketing"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-12 sm:pt-28 sm:pb-16">
    <div
      class="pointer-events-none absolute inset-0 -top-40"
      style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(249,115,22,0.10) 0%, transparent 70%)"
    ></div>
    <div class="relative mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-forge-orange to-forge-amber bg-clip-text text-transparent">
          Forge Blog
        </span>
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto">
        Tutorials, deep dives, and updates from the Forge team.
      </p>
    </div>
  </section>

  <section class="pb-20 sm:pb-28">
    <div class="mx-auto max-w-5xl px-4">
      {/* Tag filter */}
      {allTags.length > 0 && (
        <div class="mb-10 flex flex-wrap gap-2" id="tag-filter">
          <button
            data-tag="all"
            class="tag-btn px-3 py-1 text-sm font-medium rounded-full border border-forge-orange text-forge-orange transition-colors"
          >
            All
          </button>
          {allTags.map((tag) => (
            <button
              data-tag={tag}
              class="tag-btn px-3 py-1 text-sm font-medium rounded-full border border-dark-border text-gray-400 hover:border-gray-500 hover:text-white transition-colors"
            >
              {tag}
            </button>
          ))}
        </div>
      )}

      {/* Posts grid */}
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="posts-grid">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="blog-card group bg-dark-surface border border-dark-border rounded-forge-lg p-6 hover:border-gray-500 transition-colors"
              data-tags={post.data.tags.join(',')}
            >
              <div class="flex items-center gap-2 text-xs text-gray-500 mb-3">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                <span>&middot;</span>
                <span>{post.data.author}</span>
              </div>
              <h2 class="text-lg font-bold text-white group-hover:text-forge-orange transition-colors mb-2">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-400 mb-4 line-clamp-3">
                {post.data.description}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {post.data.tags.map((tag) => (
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full border border-dark-border text-gray-400">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <div class="bg-dark-surface border border-dark-border rounded-forge-lg p-12 max-w-md mx-auto">
            <h2 class="text-xl font-bold text-white mb-2">No posts yet</h2>
            <p class="text-gray-400 text-sm">
              Blog posts are coming soon. Check back later for tutorials, deep dives, and updates.
            </p>
          </div>
        </div>
      )}
    </div>
  </section>
</Base>

<script>
  const tagButtons = document.querySelectorAll('.tag-btn');
  const cards = document.querySelectorAll('.blog-card');

  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.tag;

      // Update button styles
      tagButtons.forEach((b) => {
        b.classList.remove('border-forge-orange', 'text-forge-orange');
        b.classList.add('border-dark-border', 'text-gray-400');
      });
      btn.classList.remove('border-dark-border', 'text-gray-400');
      btn.classList.add('border-forge-orange', 'text-forge-orange');

      // Filter cards
      cards.forEach((card) => {
        const cardTags = (card as HTMLElement).dataset.tags || '';
        if (tag === 'all' || cardTags.split(',').includes(tag!)) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
