---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';
import TableOfContents from '@/components/docs/TableOfContents.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const { title, description, author, date, tags, image, imageDark } = post.data;

// Reading time
const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 250));

// Related posts: share at least one tag
const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => !p.data.draft && p.id !== post.id)
  .filter((p) => p.data.tags.some((t) => tags.includes(t)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const dateFormatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const postUrl = `https://useforge.ai/blog/${post.id}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: author,
  },
  datePublished: date.toISOString(),
  publisher: {
    '@type': 'Organization',
    name: 'Initializ',
    url: 'https://initializ.ai',
  },
  url: postUrl,
};
---

<Base title={`${title} — Forge Blog`} description={description} layout="marketing" jsonLd={jsonLd}>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:py-20">
    <div class="max-w-3xl xl:mr-[260px]">
      <!-- Back link -->
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm text-secondary hover:text-heading transition-colors mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Back to Blog
      </a>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-1.5 mb-4">
          {tags.map((tag) => (
            <span class="px-2 py-0.5 text-xs font-medium rounded-full border border-dark-border text-secondary">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-heading mb-4">{title}</h1>
        <div class="flex items-center gap-3 text-sm text-secondary">
          <span>{author}</span>
          <span>&middot;</span>
          <time datetime={date.toISOString()}>{dateFormatted}</time>
          <span>&middot;</span>
          <span>{readingTime} min read</span>
        </div>
      </header>

      {image && (
        <div class="mb-10 rounded-forge-lg overflow-hidden border border-dark-border">
          {imageDark ? (
            <>
              <img src={image} alt={title} class="w-full h-auto dark:hidden" />
              <img src={imageDark} alt={title} class="w-full h-auto hidden dark:block" />
            </>
          ) : (
            <img src={image} alt={title} class="w-full h-auto" />
          )}
        </div>
      )}

      <!-- Content -->
      <article class="mb-16" data-pagefind-body>
        <div class="prose prose-orange max-w-none
          prose-headings:text-heading prose-headings:font-bold
          prose-a:text-forge-orange prose-a:no-underline hover:prose-a:underline
          prose-code:text-forge-orange/80 prose-code:bg-dark-surface prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
          prose-pre:bg-dark-surface prose-pre:border prose-pre:border-dark-border prose-pre:rounded-forge-md">
          <Content />
        </div>
      </article>

      <!-- Share buttons -->
      <div class="flex items-center gap-4 mb-16 pb-8 border-b border-dark-border">
        <span class="text-sm text-muted">Share:</span>
        <button
          id="copy-link-btn"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-secondary hover:text-heading border border-dark-border hover:border-gray-500 rounded-forge-md transition-colors"
          data-url={postUrl}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" />
            <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" />
          </svg>
          Copy link
        </button>
        <button
          id="share-x-btn"
          data-url={postUrl}
          data-title={title}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-secondary hover:text-heading border border-dark-border hover:border-gray-500 rounded-forge-md transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          Share on X
        </button>
        <button
          id="share-li-btn"
          data-url={postUrl}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-secondary hover:text-heading border border-dark-border hover:border-gray-500 rounded-forge-md transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          Share on LinkedIn
        </button>
        <button
          id="share-reddit-btn"
          data-url={postUrl}
          data-title={title}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-secondary hover:text-heading border border-dark-border hover:border-gray-500 rounded-forge-md transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 01-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 01.042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 014.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 01.14-.197.35.35 0 01.238-.042l2.906.617a1.214 1.214 0 011.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 00-.231.094.33.33 0 000 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 000-.462.342.342 0 00-.462 0c-.545.533-1.684.73-2.512.73-.828 0-1.953-.197-2.498-.73a.327.327 0 00-.219-.095z" />
          </svg>
          Share on Reddit
        </button>
      </div>

      <!-- Related posts -->
      {related.length > 0 && (
        <section>
          <h2 class="text-xl font-bold text-heading mb-6">Related Posts</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {related.map((rel) => (
              <a
                href={`/blog/${rel.id}`}
                class="group bg-dark-surface border border-dark-border rounded-forge-lg p-5 hover:border-gray-500 transition-colors"
              >
                <h3 class="text-sm font-bold text-heading group-hover:text-forge-orange transition-colors mb-2">
                  {rel.data.title}
                </h3>
                <p class="text-xs text-muted">
                  {rel.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Table of Contents -->
    <TableOfContents headings={headings} />
  </div>
</Base>

<script>
  const copyBtn = document.getElementById('copy-link-btn');
  const shareXBtn = document.getElementById('share-x-btn');
  const shareLiBtn = document.getElementById('share-li-btn');
  const shareRedditBtn = document.getElementById('share-reddit-btn');

  function buildTrackedUrl(baseUrl: string, channel: string) {
    const url = new URL(baseUrl);
    const token = crypto.randomUUID().replace(/-/g, '').slice(0, 6);
    url.searchParams.set('ref', `share_${channel}_${token}`);
    return url.toString();
  }

  copyBtn?.addEventListener('click', () => {
    const url = (copyBtn as HTMLElement).dataset.url || window.location.href;
    navigator.clipboard.writeText(url).then(() => {
      const original = copyBtn.innerHTML;
      copyBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg> Copied!';
      setTimeout(() => {
        copyBtn.innerHTML = original;
      }, 2000);
    });
  });

  shareXBtn?.addEventListener('click', () => {
    const baseUrl = (shareXBtn as HTMLElement).dataset.url || window.location.href;
    const title = (shareXBtn as HTMLElement).dataset.title || document.title;
    const trackedUrl = buildTrackedUrl(baseUrl, 'x');
    const xUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(trackedUrl)}`;
    window.open(xUrl, '_blank', 'noopener,noreferrer');
  });

  shareLiBtn?.addEventListener('click', () => {
    const baseUrl = (shareLiBtn as HTMLElement).dataset.url || window.location.href;
    const trackedUrl = buildTrackedUrl(baseUrl, 'li');
    const liUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(trackedUrl)}`;
    window.open(liUrl, '_blank', 'noopener,noreferrer');
  });

  shareRedditBtn?.addEventListener('click', () => {
    const baseUrl = (shareRedditBtn as HTMLElement).dataset.url || window.location.href;
    const title = (shareRedditBtn as HTMLElement).dataset.title || document.title;
    const trackedUrl = buildTrackedUrl(baseUrl, 'reddit');
    const redditUrl = `https://www.reddit.com/submit?url=${encodeURIComponent(trackedUrl)}&title=${encodeURIComponent(title)}`;
    window.open(redditUrl, '_blank', 'noopener,noreferrer');
  });
</script>
