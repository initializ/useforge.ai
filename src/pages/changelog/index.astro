---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';

const allEntries = await getCollection('changelog');
const entries = allEntries.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Render all entries
const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Forge Changelog',
  description: 'Release history and changelog for Forge — the secure, portable AI Agent runtime.',
  url: 'https://useforge.ai/changelog',
  publisher: {
    '@type': 'Organization',
    name: 'Initializ',
    url: 'https://initializ.ai',
  },
};
---

<Base
  title="Changelog — Forge"
  description="Release history and changelog for Forge — the secure, portable AI Agent runtime."
  layout="marketing"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-12 sm:pt-28 sm:pb-16">
    <div
      class="pointer-events-none absolute inset-0 -top-40"
      style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(249,115,22,0.10) 0%, transparent 70%)"
    ></div>
    <div class="relative mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-forge-orange to-forge-amber bg-clip-text text-transparent">
          Changelog
        </span>
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto">
        Every release, every improvement. Track Forge's evolution.
      </p>
      <div class="mt-4">
        <a
          href="/changelog/rss.xml"
          class="inline-flex items-center gap-1.5 text-sm text-forge-orange hover:text-forge-amber transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M4 11a9 9 0 019 9M4 4a16 16 0 0116 16" />
            <circle cx="5" cy="19" r="1" />
          </svg>
          RSS Feed
        </a>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="pb-20 sm:pb-28">
    <div class="mx-auto max-w-4xl px-4">
      <div class="border-l-2 border-dark-border ml-4 sm:ml-8 space-y-12">
        {rendered.map(({ entry, Content }, i) => {
          const isLatest = i === 0;
          const dateFormatted = entry.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <div class="relative pl-8 sm:pl-12">
              {/* Timeline dot */}
              <div
                class:list={[
                  'absolute -left-[9px] top-1 w-4 h-4 rounded-full border-2',
                  isLatest
                    ? 'bg-forge-orange border-forge-orange'
                    : 'bg-dark-surface border-dark-border',
                ]}
              />

              {/* Version badge + date */}
              <div class="flex flex-wrap items-center gap-3 mb-4">
                <span
                  class:list={[
                    'inline-flex items-center px-3 py-1 text-sm font-bold rounded-full',
                    isLatest
                      ? 'bg-forge-orange text-white'
                      : 'bg-dark-surface text-gray-300 border border-dark-border',
                  ]}
                >
                  v{entry.data.version}
                </span>
                {entry.data.breaking && (
                  <span class="inline-flex items-center px-2 py-0.5 text-xs font-bold rounded-full bg-red-900/40 border border-red-700 text-red-400">
                    BREAKING
                  </span>
                )}
                <time class="text-sm text-gray-500" datetime={entry.data.date.toISOString()}>
                  {dateFormatted}
                </time>
              </div>

              {/* Content */}
              <div class="prose prose-invert prose-orange max-w-none prose-sm
                prose-headings:text-white prose-headings:font-bold
                prose-a:text-forge-orange prose-a:no-underline hover:prose-a:underline
                prose-code:text-forge-orange/80 prose-code:bg-dark-surface prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                prose-pre:bg-dark-surface prose-pre:border prose-pre:border-dark-border prose-pre:rounded-forge-md">
                <Content />
              </div>

              {/* View on GitHub */}
              {entry.data.githubUrl && (
                <a
                  href={entry.data.githubUrl}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1.5 mt-4 text-sm text-gray-400 hover:text-white transition-colors"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                  </svg>
                  View on GitHub
                </a>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>
</Base>
