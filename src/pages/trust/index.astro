---
import Base from '@/layouts/Base.astro';
import SecurityStack from '@/components/SecurityStack.astro';

// Load trust data at build time with fallback
let trustData = {
  ciStatus: 'unknown',
  ciUrl: 'https://github.com/initializ/forge/actions',
  latestVersion: '',
  latestDate: '',
  securityAdvisories: 0,
  license: 'Apache-2.0',
  fetchedAt: '',
};

try {
  const raw = await import('@/data/trust-data.json');
  trustData = { ...trustData, ...raw.default };
} catch {
  // trust-data.json not generated yet — use placeholders
}

// Also pull latest release from releases.json as backup
if (!trustData.latestVersion) {
  try {
    const releases = await import('@/data/releases.json');
    const list = releases.default as Array<{ version: string; date: string }>;
    if (list.length > 0) {
      trustData.latestVersion = list[0].version;
      trustData.latestDate = list[0].date;
    }
  } catch {}
}

const ciColor =
  trustData.ciStatus === 'success'
    ? 'text-green-400'
    : trustData.ciStatus === 'failure'
      ? 'text-red-400'
      : 'text-gray-400';

const ciLabel =
  trustData.ciStatus === 'success'
    ? 'Passing'
    : trustData.ciStatus === 'failure'
      ? 'Failing'
      : 'Unknown';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Forge Trust & Security',
  description:
    'Comprehensive security architecture documentation for Forge — the secure, portable AI Agent runtime.',
  publisher: {
    '@type': 'Organization',
    name: 'Initializ',
    url: 'https://initializ.ai',
  },
  url: 'https://useforge.ai/trust',
};

const ndjsonExample = `{"ts":"2026-02-28T10:00:00Z","event":"session_start","correlation_id":"a1b2c3d4","task_id":"task-1"}
{"ts":"2026-02-28T10:00:01Z","event":"tool_exec","correlation_id":"a1b2c3d4","fields":{"tool":"tavily_research","phase":"start"}}
{"ts":"2026-02-28T10:00:01Z","event":"egress_allowed","correlation_id":"a1b2c3d4","fields":{"domain":"api.tavily.com","mode":"allowlist","source":"proxy"}}
{"ts":"2026-02-28T10:00:05Z","event":"tool_exec","correlation_id":"a1b2c3d4","fields":{"tool":"tavily_research","phase":"end"}}
{"ts":"2026-02-28T10:00:06Z","event":"session_end","correlation_id":"a1b2c3d4","fields":{"state":"completed"}}`;
---

<Base
  title="Trust & Security — Forge"
  description="Comprehensive security architecture documentation for Forge — the secure, portable AI Agent runtime."
  jsonLd={jsonLd}
>
  <!-- ─── A. Hero ─── -->
  <section class="relative py-20 sm:py-28 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-forge-orange/5 rounded-full blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-4xl px-4 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight">
        Forge Trust &amp; Security
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-gray-400 leading-relaxed max-w-3xl mx-auto">
        Forge is a secure, portable AI Agent runtime. Run agents locally, in cloud, or enterprise environments without exposing inbound tunnels. Here's how.
      </p>
    </div>
  </section>

  <!-- ─── B. Project Health Dashboard ─── -->
  <section id="project-health" class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4">
      <p class="text-sm font-medium text-forge-orange uppercase tracking-wider mb-4">Project Health</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-8">
        <a href="#project-health" class="hover:text-forge-orange transition-colors">Live Status</a>
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- CI Status -->
        <a href={trustData.ciUrl} target="_blank" rel="noopener noreferrer" class="bg-dark-surface border border-dark-border rounded-forge-md p-5 hover:border-dark-hover transition-colors group">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-4 h-4 text-gray-500 group-hover:text-forge-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-xs text-gray-500 uppercase tracking-wide">CI Status</span>
          </div>
          <p class:list={['text-lg font-semibold', ciColor]}>{ciLabel}</p>
        </a>

        <!-- Latest Release -->
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" />
            </svg>
            <span class="text-xs text-gray-500 uppercase tracking-wide">Latest Release</span>
          </div>
          <p class="text-lg font-semibold text-white">
            {trustData.latestVersion ? `v${trustData.latestVersion.replace(/^v/, '')}` : '—'}
          </p>
          {trustData.latestDate && (
            <p class="text-xs text-gray-500 mt-1">{trustData.latestDate}</p>
          )}
        </div>

        <!-- Security Advisories -->
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            <span class="text-xs text-gray-500 uppercase tracking-wide">Advisories</span>
          </div>
          <p class:list={[
            'text-lg font-semibold',
            trustData.securityAdvisories === 0 ? 'text-green-400' : 'text-yellow-400',
          ]}>
            {trustData.securityAdvisories}
          </p>
          <p class="text-xs text-gray-500 mt-1">published</p>
        </div>

        <!-- License -->
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span class="text-xs text-gray-500 uppercase tracking-wide">License</span>
          </div>
          <p class="text-lg font-semibold text-white">{trustData.license}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── C. Security Architecture Overview ─── -->
  <section id="security-architecture" class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4">
      <p class="text-sm font-medium text-forge-orange uppercase tracking-wider mb-4">Architecture</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">
        <a href="#security-architecture" class="hover:text-forge-orange transition-colors">Security Architecture</a>
      </h2>
      <div class="border-l-4 border-l-forge-orange bg-dark-surface rounded-forge-md p-6 mb-10">
        <p class="text-white text-lg leading-relaxed">
          Atomicity. Security. Portability. Every layer of Forge's architecture is designed to make these properties <em class="text-forge-orange not-italic font-medium">verifiable</em>, not just claimed.
        </p>
      </div>
      <p class="text-gray-400 leading-relaxed mb-8 max-w-3xl">
        Forge's security is organized as a defense-in-depth stack. Each layer addresses a different threat surface, and layers are independently enforceable. No single layer failing compromises the entire system.
      </p>
      <div class="max-w-3xl">
        <SecurityStack />
      </div>
    </div>
  </section>

  <!-- ─── D. Network Posture ─── -->
  <section id="network-posture" class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4">
      <p class="text-sm font-medium text-forge-orange uppercase tracking-wider mb-4">Layer 6</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">
        <a href="#network-posture" class="hover:text-forge-orange transition-colors">Network Posture</a>
      </h2>
      <p class="text-gray-400 leading-relaxed mb-8 max-w-3xl">
        A running Forge agent has <strong class="text-white">zero inbound attack surface</strong> by default. This is a fundamental design constraint, not a configuration option.
      </p>
      <div class="grid sm:grid-cols-2 gap-4 max-w-4xl">
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <h3 class="text-white font-semibold mb-2">No Public Tunnels</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Forge does not create ngrok, Cloudflare, or similar tunnels. There is no mechanism for inbound connections from the public internet.</p>
        </div>
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <h3 class="text-white font-semibold mb-2">No Inbound Webhooks</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Channels use outbound-only connections. Slack uses Socket Mode (outbound WebSocket via <code class="text-forge-orange text-xs">apps.connections.open</code>). Telegram uses long-polling via <code class="text-forge-orange text-xs">getUpdates</code>.</p>
        </div>
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <h3 class="text-white font-semibold mb-2">Local-Only HTTP</h3>
          <p class="text-gray-400 text-sm leading-relaxed">The A2A dev server binds to <code class="text-forge-orange text-xs">localhost</code> by default. It is never exposed to the network without explicit configuration.</p>
        </div>
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <h3 class="text-white font-semibold mb-2">Explicit Bindings</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Every network binding is explicit and logged. No hidden listeners, no background services, no surprise ports.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── E. Egress Control ─── -->
  <section id="egress-control" class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4">
      <p class="text-sm font-medium text-forge-orange uppercase tracking-wider mb-4">Layer 5</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">
        <a href="#egress-control" class="hover:text-forge-orange transition-colors">Egress Control</a>
      </h2>
      <p class="text-gray-400 leading-relaxed mb-8 max-w-3xl">
        Forge restricts outbound network access at three independent levels, each catching traffic that could bypass the previous layer.
      </p>

      <!-- Three-level enforcement -->
      <h3 class="text-lg font-semibold text-white mb-4">Three-Level Enforcement</h3>
      <div class="grid sm:grid-cols-3 gap-4 mb-10 max-w-5xl">
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <div class="text-forge-orange font-mono text-xs mb-2">Level 1</div>
          <h4 class="text-white font-semibold mb-2">In-Process Enforcer</h4>
          <p class="text-gray-400 text-sm leading-relaxed">A Go <code class="text-forge-orange text-xs">http.RoundTripper</code> wraps every outbound HTTP request from in-process tools. Validates destination domain against the resolved allowlist before forwarding.</p>
        </div>
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <div class="text-forge-orange font-mono text-xs mb-2">Level 2</div>
          <h4 class="text-white font-semibold mb-2">Subprocess Proxy</h4>
          <p class="text-gray-400 text-sm leading-relaxed">A local <code class="text-forge-orange text-xs">EgressProxy</code> on <code class="text-forge-orange text-xs">127.0.0.1:&lt;port&gt;</code> validates domains for subprocess HTTP traffic via <code class="text-forge-orange text-xs">HTTP_PROXY</code>/<code class="text-forge-orange text-xs">HTTPS_PROXY</code> injection.</p>
        </div>
        <div class="bg-dark-surface border border-dark-border rounded-forge-md p-5">
          <div class="text-forge-orange font-mono text-xs mb-2">Level 3</div>
          <h4 class="text-white font-semibold mb-2">Kubernetes NetworkPolicy</h4>
          <p class="text-gray-400 text-sm leading-relaxed">In containerized deployments, generated Kubernetes <code class="text-forge-orange text-xs">NetworkPolicy</code> manifests enforce egress at the pod level, restricting traffic to allowed domains on ports 80/443.</p>
        </div>
      </div>

      <!-- Proxy architecture -->
      <h3 class="text-lg font-semibold text-white mb-4">Proxy Architecture</h3>
      <div class="bg-dark-surface border border-dark-border rounded-forge-md p-4 sm:p-6 font-mono text-sm text-gray-300 overflow-x-auto mb-10 max-w-3xl">
        <pre class="whitespace-pre"><code>┌─────────────────────────────────────────────────────┐
│                   forge run                         │
│                                                     │
│  In-process HTTP ──→ EgressEnforcer (RoundTripper)  │
│                                                     │
│  Subprocesses ──→ HTTP_PROXY ──→ EgressProxy        │
│  (curl, wget,       127.0.0.1:&lt;port&gt;  (validates   │
│   python, etc.)                        domains)     │
└─────────────────────────────────────────────────────┘</code></pre>
      </div>

      <!-- Three modes -->
      <h3 class="text-lg font-semibold text-white mb-4">Egress Modes</h3>
      <div class="overflow-x-auto mb-10 max-w-3xl">
        <table class="w-full text-sm border border-dark-border rounded-forge-md overflow-hidden">
          <thead>
            <tr class="bg-dark-surface">
              <th class="text-left px-4 py-3 text-gray-400 font-medium border-b border-dark-border">Mode</th>
              <th class="text-left px-4 py-3 text-gray-400 font-medium border-b border-dark-border">Behavior</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-dark-border">
              <td class="px-4 py-3 text-white font-mono text-xs">deny-all</td>
              <td class="px-4 py-3 text-gray-300">All non-localhost outbound traffic blocked</td>
            </tr>
            <tr class="border-b border-dark-border bg-dark-surface/50">
              <td class="px-4 py-3 text-white font-mono text-xs">allowlist</td>
              <td class="px-4 py-3 text-gray-300">Only explicitly allowed domains (exact + wildcard)</td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-white font-mono text-xs">dev-open</td>
              <td class="px-4 py-3 text-gray-300">All traffic allowed (development only)</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Domain matching -->
      <h3 class="text-lg font-semibold text-white mb-4">Domain Matching Rules</h3>
      <ul class="space-y-2 text-gray-400 text-sm mb-10 max-w-3xl">
        <li class="flex items-start gap-2">
          <span class="text-forge-orange mt-1 shrink-0">&bull;</span>
          <span><strong class="text-white">Exact match:</strong> <code class="text-forge-orange text-xs">api.openai.com</code> matches <code class="text-forge-orange text-xs">api.openai.com</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-forge-orange mt-1 shrink-0">&bull;</span>
          <span><strong class="text-white">Wildcard match:</strong> <code class="text-forge-orange text-xs">*.github.com</code> matches <code class="text-forge-orange text-xs">api.github.com</code> but not <code class="text-forge-orange text-xs">github.com</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-forge-orange mt-1 shrink-0">&bull;</span>
          <span><strong class="text-white">Case insensitive:</strong> <code class="text-forge-orange text-xs">API.OpenAI.COM</code> matches <code class="text-forge-orange text-xs">api.openai.com</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-forge-orange mt-1 shrink-0">&bull;</span>
          <span><strong class="text-white">Localhost bypass:</strong> <code class="text-forge-orange text-xs">127.0.0.1</code>, <code class="text-forge-orange text-xs">::1</code>, and <code class="text-forge-orange text-xs">localhost</code> are always allowed in all modes</span>
        </li>
      </ul>

      <!-- Domain resolution -->
      <h3 class="text-lg font-semibold text-white mb-4">Domain Resolution</h3>
      <p class="text-gray-400 text-sm leading-relaxed mb-4 max-w-3xl">
        Allowed domains are resolved from three sources, combined and deduplicated:
      </p>
      <ol class="space-y-2 text-gray-400 text-sm mb-10 max-w-3xl list-decimal list-inside">
        <li><strong class="text-white">Explicit domains</strong> — listed in <code class="text-forge-orange text-xs">forge.yaml</code> under <code class="text-forge-orange text-xs">egress.allowed_domains</code></li>
        <li><strong class="text-white">Tool domains</strong> — automatically inferred from registered tool names (e.g., <code class="text-forge-orange text-xs">web_search</code> &rarr; <code class="text-forge-orange text-xs">api.tavily.com</code>)</li>
        <li><strong class="text-white">Capability bundles</strong> — pre-defined domain sets for common services (e.g., <code class="text-forge-orange text-xs">slack</code> &rarr; <code class="text-forge-orange text-xs">slack.com</code>, <code class="text-forge-orange text-xs">hooks.slack.com</code>, <code class="text-forge-orange text-xs">api.slack.com</code>)</li>
      </ol>

      <!-- forge.yaml config example -->
      <h3 class="text-lg font-semibold text-white mb-4">Configuration</h3>
      <div class="bg-dark-surface border border-dark-border rounded-forge-md p-4 font-mono text-sm text-gray-300 overflow-x-auto mb-10 max-w-3xl">
        <pre><code><span class="text-gray-500"># forge.yaml</span>
<span class="text-forge-orange">egress:</span>
  <span class="text-forge-orange">profile:</span> standard
  <span class="text-forge-orange">mode:</span> allowlist
  <span class="text-forge-orange">allowed_domains:</span>
    - api.example.com
    - "*.github.com"
    - hooks.slack.com
  <span class="text-forge-orange">capabilities:</span>
    - slack
    - telegram</code></pre>
      </div>

      <!-- Production vs Development -->
      <h3 class="text-lg font-semibold text-white mb-4">Production vs Development</h3>
      <div class="overflow-x-auto max-w-3xl">
        <table class="w-full text-sm border border-dark-border rounded-forge-md overflow-hidden">
          <thead>
            <tr class="bg-dark-surface">
              <th class="text-left px-4 py-3 text-gray-400 font-medium border-b border-dark-border">Setting</th>
              <th class="text-left px-4 py-3 text-gray-400 font-medium border-b border-dark-border">Production</th>
              <th class="text-left px-4 py-3 text-gray-400 font-medium border-b border-dark-border">Development</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-dark-border">
              <td class="px-4 py-3 text-white">Profile</td>
              <td class="px-4 py-3 text-gray-300 font-mono text-xs">strict / standard</td>
              <td class="px-4 py-3 text-gray-300 font-mono text-xs">permissive</td>
            </tr>
            <tr class="border-b border-dark-border bg-dark-surface/50">
              <td class="px-4 py-3 text-white">Mode</td>
              <td class="px-4 py-3 text-gray-300 font-mono text-xs">deny-all / allowlist</td>
              <td class="px-4 py-3 text-gray-300 font-mono text-xs">dev-open</td>
            </tr>
            <tr class="border-b border-dark-border">
              <td class="px-4 py-3 text-white">Dev tools</td>
              <td class="px-4 py-3 text-gray-300">Filtered out</td>
              <td class="px-4 py-3 text-gray-300">Included</td>
            </tr>
            <tr class="border-b border-dark-border bg-dark-surface/50">
              <td class="px-4 py-3 text-white">Network policy</td>
              <td class="px-4 py-3 text-gray-300">Enforced</td>
              <td class="px-4 py-3 text-gray-300">Not generated</td>
            </tr>
            <tr class="border-b border-dark-border">
              <td class="px-4 py-3 text-white">Egress proxy</td>
              <td class="px-4 py-3 text-gray-300">Active</td>
              <td class="px-4 py-3 text-gray-300">Skipped</td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-white">Container egress</td>
              <td class="px-4 py-3 text-gray-300">NetworkPolicy</td>
              <td class="px-4 py-3 text-gray-300">Proxy</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ─── F. Execution Sandboxing ─── -->
  <section id="execution-sandboxing" class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4">
      <p class="text-sm font-medium text-forge-orange uppercase tracking-wider mb-4">Layer 4</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">
        <a href="#execution-sandboxing" class="hover:text-forge-orange transition-colors">Execution Sandboxing</a>
      </h2>
      <p class="text-gray-400 leading-relaxed mb-8 max-w-3xl">
        Forge agents execute external code through two sandboxed executors, both designed to minimize the attack surface of subprocess execution.
      </p>

      <!-- SkillCommandExecutor -->
      <h3 class="text-lg font-semibold text-white mb-4">SkillCommandExecutor</h3>
      <p class="text-gray-400 text-sm leading-relaxed mb-4 max-w-3xl">
        Skill scripts run via <code class="text-forge-orange text-xs">SkillCommandExecutor</code> with the following controls:
      </p>
      <div class="overflow-x-auto mb-10 max-w-3xl">
        <table class="w-full text-sm border border-dark-border rounded-forge-md overflow-hidden">
          <thead>
            <tr class="bg-dark-surface">
              <th class="text-left px-4 py-3 text-gray-400 font-medium border-b border-dark-border">Control</th>
              <th class="text-left px-4 py-3 text-gray-400 font-medium border-b border-dark-border">Detail</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-dark-border">
              <td class="px-4 py-3 text-white">Environment isolation</td>
              <td class="px-4 py-3 text-gray-300">Only <code class="text-forge-orange text-xs">PATH</code>, <code class="text-forge-orange text-xs">HOME</code>, and explicitly declared env vars passed through</td>
            </tr>
            <tr class="border-b border-dark-border bg-dark-surface/50">
              <td class="px-4 py-3 text-white">Egress proxy injection</td>
              <td class="px-4 py-3 text-gray-300"><code class="text-forge-orange text-xs">HTTP_PROXY</code>/<code class="text-forge-orange text-xs">HTTPS_PROXY</code> route subprocess HTTP through the egress proxy</td>
            </tr>
            <tr class="border-b border-dark-border">
              <td class="px-4 py-3 text-white">Configurable timeout</td>
              <td class="px-4 py-3 text-gray-300">Per-skill <code class="text-forge-orange text-xs">timeout_hint</code> in YAML frontmatter (default: 120s)</td>
            </tr>
            <tr class="border-b border-dark-border bg-dark-surface/50">
              <td class="px-4 py-3 text-white">No shell</td>
