              <td class="px-4 py-3 text-red-400 font-medium">Critical</td>
            </tr>
            <tr class="border-b border-dark-border bg-dark-surface/50">
              <td class="px-4 py-3 text-white">Hardcoded secrets</td>
              <td class="px-4 py-3 text-gray-300"><code class="text-forge-orange text-xs">API_KEY=...</code> patterns in scripts</td>
              <td class="px-4 py-3 text-red-400 font-medium">Critical</td>
            </tr>
            <tr class="border-b border-dark-border">
              <td class="px-4 py-3 text-white">Broad binary request</td>
              <td class="px-4 py-3 text-gray-300">Requiring <code class="text-forge-orange text-xs">bash</code>, <code class="text-forge-orange text-xs">sh</code> directly</td>
