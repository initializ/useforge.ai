---
import Base from '@/layouts/Base.astro';
---

<Base title="404 — Page Not Found">
  <main class="min-h-screen flex flex-col items-center justify-center gap-4 p-8">
    <h1 class="text-6xl font-bold text-forge-orange">404</h1>
    <p class="text-secondary text-lg">Page not found.</p>
    <a href="/" class="text-forge-amber hover:text-forge-orange transition-colors">
      Back to home
    </a>
  </main>
</Base>
