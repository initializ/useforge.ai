---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return skills.map((skill) => ({
    params: { slug: skill.id },
    props: { skill },
  }));
}

const { skill } = Astro.props;
const { Content } = await render(skill);

const { name, description, trustLevel, bins, envRequired, envOneOf, egressDomains, publisher } = skill.data;

const trustConfig: Record<string, { label: string; color: string; bg: string; explanation: string }> = {
  trusted: {
    label: 'Trusted',
    color: 'text-green-400',
    bg: 'bg-green-900/40 border-green-700',
    explanation: 'This skill has been reviewed and signed by the Forge team.',
  },
  under_review: {
    label: 'Under Review',
    color: 'text-yellow-400',
    bg: 'bg-yellow-900/40 border-yellow-700',
    explanation: 'This skill is pending review by the Forge team.',
  },
  untrusted: {
    label: 'Untrusted',
    color: 'text-red-400',
    bg: 'bg-red-900/40 border-red-700',
    explanation: 'This skill has not been reviewed. Use with caution.',
  },
  failed: {
    label: 'Failed Review',
    color: 'text-red-400',
    bg: 'bg-red-900/40 border-red-700',
    explanation: 'This skill failed the review process and may be unsafe.',
  },
};

const trust = trustConfig[trustLevel] || trustConfig.untrusted;

const hasRequirements = bins.length > 0 || envRequired.length > 0 || envOneOf.length > 0 || egressDomains.length > 0;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name,
  description,
  applicationCategory: 'AI Agent Skill',
  publisher: {
    '@type': 'Organization',
    name: publisher,
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<Base
  title={`${name} — Forge Skill Hub`}
  description={description}
  layout="marketing"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:py-20">
    <!-- Back link -->
    <a
      href="/hub"
      class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-white transition-colors mb-8"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      Back to Hub
    </a>

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-8">
      <div class="flex-1">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">{name}</h1>
        <p class="text-lg text-gray-400">{description}</p>
      </div>
      <span class={`shrink-0 inline-flex items-center px-3 py-1 text-sm font-medium rounded-full border ${trust.bg} ${trust.color}`}>
        {trust.label}
      </span>
    </div>

    <!-- Install command -->
    <div class="mb-8">
      <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wider mb-2">Install</h2>
      <div class="relative group">
        <pre class="bg-dark-surface border border-dark-border rounded-forge-md p-4 font-mono text-sm text-gray-200 overflow-x-auto"><code>forge skills add {skill.id}</code></pre>
        <button
          class="copy-btn absolute top-2 right-2 p-1.5 rounded bg-dark-border/50 text-gray-500 hover:text-white opacity-0 group-hover:opacity-100 transition-opacity"
          data-copy={`forge skills add ${skill.id}`}
          aria-label="Copy install command"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Requirements panel -->
    {hasRequirements && (
      <div class="mb-8">
        <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wider mb-3">Requirements</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {bins.length > 0 && (
            <div class="bg-dark-surface border border-dark-border rounded-forge-md p-4">
              <h3 class="text-xs font-medium text-gray-500 uppercase mb-2">Binary Dependencies</h3>
              <div class="flex flex-wrap gap-2">
                {bins.map((bin: string) => (
                  <code class="px-2 py-0.5 bg-dark-bg rounded text-sm text-gray-300 font-mono">{bin}</code>
                ))}
              </div>
            </div>
          )}
          {envRequired.length > 0 && (
            <div class="bg-dark-surface border border-dark-border rounded-forge-md p-4">
              <h3 class="text-xs font-medium text-gray-500 uppercase mb-2">Required Env Vars</h3>
              <div class="flex flex-wrap gap-2">
                {envRequired.map((env: string) => (
                  <code class="px-2 py-0.5 bg-dark-bg rounded text-sm text-forge-orange/80 font-mono">{env}</code>
                ))}
              </div>
            </div>
          )}
          {envOneOf.length > 0 && (
            <div class="bg-dark-surface border border-dark-border rounded-forge-md p-4">
              <h3 class="text-xs font-medium text-gray-500 uppercase mb-2">One Of (Env Vars)</h3>
              <div class="flex flex-wrap gap-2">
                {envOneOf.map((env: string) => (
                  <code class="px-2 py-0.5 bg-dark-bg rounded text-sm text-spark-mid font-mono">{env}</code>
                ))}
              </div>
            </div>
          )}
          {egressDomains.length > 0 && (
            <div class="bg-dark-surface border border-dark-border rounded-forge-md p-4">
              <h3 class="text-xs font-medium text-gray-500 uppercase mb-2">Egress Domains</h3>
              <div class="flex flex-wrap gap-2">
                {egressDomains.map((domain: string) => (
                  <code class={`px-2 py-0.5 bg-dark-bg rounded text-sm font-mono ${domain.startsWith('$') ? 'text-spark-mid' : 'text-gray-300'}`}>{domain}</code>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    )}

    <!-- Skill body (rendered markdown) -->
    <div class="mb-8" data-pagefind-body>
      <div class="prose prose-invert prose-orange max-w-none
        prose-headings:text-white prose-headings:font-bold
        prose-a:text-forge-orange prose-a:no-underline hover:prose-a:underline
        prose-code:text-forge-orange/80 prose-code:bg-dark-surface prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
        prose-pre:bg-dark-surface prose-pre:border prose-pre:border-dark-border prose-pre:rounded-forge-md">
        <Content />
      </div>
    </div>

    <!-- Security summary -->
    <div class="bg-dark-surface border border-dark-border rounded-forge-lg p-6 mb-8">
      <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wider mb-3">Security Summary</h2>
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <span class={`mt-0.5 ${trust.color}`}>
            {trustLevel === 'trusted' ? (
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            ) : (
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
            )}
          </span>
          <div>
            <p class="text-sm text-gray-300 font-medium">Trust Level: <span class={trust.color}>{trust.label}</span></p>
            <p class="text-xs text-gray-500 mt-0.5">{trust.explanation}</p>
          </div>
        </div>
        {egressDomains.length > 0 && (
          <div class="flex items-start gap-3">
            <span class="mt-0.5 text-gray-500">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            </span>
            <div>
              <p class="text-sm text-gray-300 font-medium">Network Access</p>
              <p class="text-xs text-gray-500 mt-0.5">
                This skill communicates with:
                {egressDomains.map((d: string, i: number) => (
                  <span>
                    {i > 0 && ', '}
                    {d.startsWith('$') ? (
                      <code class="text-spark-mid">{d}</code>
                    ) : (
                      <code class="text-gray-300">{d}</code>
                    )}
                  </span>
                ))}
              </p>
            </div>
          </div>
        )}
        {egressDomains.length === 0 && (
          <div class="flex items-start gap-3">
            <span class="mt-0.5 text-green-500">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M5 13l4 4L19 7" />
              </svg>
            </span>
            <div>
              <p class="text-sm text-gray-300 font-medium">No Network Access</p>
              <p class="text-xs text-gray-500 mt-0.5">This skill does not make external network requests.</p>
            </div>
          </div>
        )}
        <div class="flex items-start gap-3">
          <span class="mt-0.5 text-gray-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </span>
          <div>
            <p class="text-sm text-gray-300 font-medium">Publisher: {publisher.toLowerCase() === 'forge' ? (
              <a href="https://useforge.ai" class="text-forge-orange hover:text-forge-amber transition-colors">Forge</a>
            ) : (
              <span class="text-gray-200">{publisher}</span>
            )}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Back link -->
    <a
      href="/hub"
      class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-white transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      Back to Hub
    </a>
  </div>
</Base>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      navigator.clipboard.writeText(text).then(() => {
        const el = btn as HTMLElement;
        el.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg>';
        setTimeout(() => {
          el.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" /></svg>';
        }, 2000);
      });
    });
  });
</script>
