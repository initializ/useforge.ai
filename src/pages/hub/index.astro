---
import fs from 'node:fs';
import path from 'node:path';
import Base from '@/layouts/Base.astro';
import SkillBrowser from '@/components/SkillBrowser.tsx';

interface SkillMeta {
  slug: string;
  name: string;
  description: string;
  trustLevel: string;
  bins: string[];
  envRequired: string[];
  envOneOf: string[];
  egressDomains: string[];
  publisher: string;
}

let skills: SkillMeta[] = [];
try {
  const filePath = path.resolve('src/data/skills.json');
  if (fs.existsSync(filePath)) {
    skills = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
  }
} catch {
  // skills.json doesn't exist yet — SkillBrowser handles empty array
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Forge Skill Hub',
  description: 'Discover, install, and compose agent skills for Forge.',
  numberOfItems: skills.length,
  itemListElement: skills.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.name,
    url: `https://useforge.ai/hub/skills/${s.slug}`,
  })),
};
---

<Base
  title="Skill Hub — Forge"
  description="Discover, install, and compose agent skills. Each skill is a portable SKILL.md — reviewed, signed, and sandboxed."
  layout="marketing"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-12 sm:pt-28 sm:pb-16">
    <!-- Radial glow -->
    <div
      class="pointer-events-none absolute inset-0 -top-40"
      style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(249,115,22,0.10) 0%, transparent 70%)"
    ></div>

    <div class="relative mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-forge-orange to-forge-amber bg-clip-text text-transparent">
          Skill Hub
        </span>
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto">
        Discover, install, and compose agent skills. Each skill is a portable
        <code class="text-forge-orange/80 text-base">SKILL.md</code> — reviewed, signed, and sandboxed.
      </p>
      <div class="mt-6">
        <a
          href="/docs/skills/embedded-skills"
          class="inline-flex items-center gap-2 text-sm text-forge-orange hover:text-forge-amber transition-colors"
        >
          Learn about skills
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Skill Browser -->
  <section class="pb-16 sm:pb-24">
    <div class="mx-auto max-w-7xl px-4">
      <SkillBrowser client:load skills={skills} />
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="pb-20 sm:pb-28">
    <div class="mx-auto max-w-xl px-4 text-center">
      <div class="bg-dark-surface border border-dark-border rounded-forge-xl p-8">
        <h2 class="text-xl font-bold text-white mb-2">Write Your Own Skill</h2>
        <p class="text-gray-400 text-sm mb-5">
          Skills are just markdown files with frontmatter. Create one in minutes.
        </p>
        <a
          href="/docs/getting-started/your-first-skill"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-forge-orange hover:bg-forge-deep text-white text-sm font-medium rounded-forge-md transition-colors"
        >
          Get started
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Base>
