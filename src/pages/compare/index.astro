---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';

const allComparisons = await getCollection('comparisons');
const comparisons = allComparisons.sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const byCategory = {
  'managed-runtime': comparisons.filter((c) => c.data.category === 'managed-runtime'),
  'framework': comparisons.filter((c) => c.data.category === 'framework'),
  'personal-vs-enterprise': comparisons.filter((c) => c.data.category === 'personal-vs-enterprise'),
};

const sections = [
  {
    id: 'managed-runtime',
    heading: 'Managed cloud runtimes',
    intro:
      'Hyperscalers and Anthropic each ship a managed agent runtime. They run in their own clouds and bill through their own platforms. Forge runs in yours.',
    cards: byCategory['managed-runtime'],
  },
  {
    id: 'framework',
    heading: 'Agent frameworks',
    intro:
      'Frameworks give you Python or TypeScript abstractions to build an agent. Forge gives you a runtime to deploy one — and the frameworks below can run inside it as scripts within a SKILL.md.',
    cards: byCategory['framework'],
  },
  {
    id: 'personal-vs-enterprise',
    heading: 'Personal vs enterprise agents',
    intro:
      'Some agent runtimes target one user on one machine. Forge targets one service in your infrastructure. Different blast radius, different security model, different operational shape.',
    cards: byCategory['personal-vs-enterprise'],
  },
];

const metaDescription =
  'Compare Forge against managed cloud runtimes (AgentCore, Foundry, Vertex, Claude Managed Agents), agent frameworks (LangChain, CrewAI), and personal-agent tools (OpenClaw). When to use each, when to choose Forge.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Compare Forge',
  description: metaDescription,
  numberOfItems: comparisons.length,
  itemListElement: comparisons.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.data.title,
    url: `https://useforge.ai/compare/${c.id}`,
    description: c.data.description,
  })),
};
---

<Base
  title="Compare Forge — Forge"
  description={metaDescription}
  layout="marketing"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-12 sm:pt-28 sm:pb-16">
    <div
      class="pointer-events-none absolute inset-0 -top-40"
      style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(249,115,22,0.10) 0%, transparent 70%)"
    ></div>
    <div class="relative mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-forge-orange to-forge-amber bg-clip-text text-transparent">
          Compare Forge
        </span>
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-secondary max-w-2xl mx-auto">
        When agents move from desktop tasks to production services, the runtime layer changes
        everything. Forge is the open-source agent runtime built on Anthropic's Agent Skills
        standard — designed for the agent that runs next to a service, in your environment, on
        infrastructure you already operate. See how Forge compares across three categories:
        managed cloud runtimes, agent frameworks, and the personal-agent ecosystem.
      </p>
    </div>
  </section>

  <!-- Categorized comparison sections -->
  <div class="mx-auto max-w-4xl px-4 pb-20 sm:pb-28">
    {sections.map((section) => (
      <section class="mb-16 last:mb-0">
        <h2 class="text-2xl font-bold text-heading mb-2">{section.heading}</h2>
        <p class="text-sm text-secondary mb-6 max-w-2xl">{section.intro}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {section.cards.map((comp) => (
            <a
              href={`/compare/${comp.id}`}
              class="group bg-dark-surface border border-dark-border rounded-forge-lg p-6 hover:border-gray-500 transition-colors"
            >
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-medium uppercase tracking-wider text-muted">vs</span>
                <span class="text-sm font-bold text-forge-orange">{comp.data.competitor}</span>
              </div>
              <h3 class="text-lg font-bold text-heading group-hover:text-forge-orange transition-colors mb-2">
                {comp.data.title}
              </h3>
              <p class="text-sm text-secondary line-clamp-3">
                {comp.data.description}
              </p>
              <span class="inline-flex items-center gap-1 mt-4 text-sm text-forge-orange group-hover:text-forge-amber transition-colors">
                Read comparison
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))}
        </div>

        {section.id === 'personal-vs-enterprise' && (
          <div class="mt-8">
            <a
              href="/openclaw-enterprise"
              class="group block bg-dark-surface border border-dark-border rounded-forge-xl p-6 hover:border-forge-orange/50 transition-colors"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <span class="inline-block px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-forge-orange bg-forge-orange/10 rounded-full mb-3">
                    Enterprise
                  </span>
                  <h3 class="text-lg font-bold text-heading group-hover:text-forge-orange transition-colors mb-2">
                    OpenClaw for Enterprise Environments
                  </h3>
                  <p class="text-sm text-secondary">
                    Detailed architecture comparison, security analysis, and FAQ for teams evaluating enterprise AI agent deployment.
                  </p>
                </div>
                <svg class="w-5 h-5 text-muted group-hover:text-forge-orange transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          </div>
        )}
      </section>
    ))}
  </div>
</Base>
