---
import Base from './Base.astro';
import DocsSidebar from '@/components/docs/DocsSidebar.astro';
import TableOfContents from '@/components/docs/TableOfContents.astro';
import Breadcrumbs from '@/components/docs/Breadcrumbs.astro';
import PrevNextNav from '@/components/docs/PrevNextNav.astro';
import CopyCodeButton from '@/components/docs/CopyCodeButton.astro';
import { flattenNav } from '@/data/navigation';

interface Props {
  title: string;
  description: string;
  headings: Array<{ depth: number; slug: string; text: string }>;
  editUrl?: string;
  lastUpdated?: Date;
  currentSlug: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, headings, editUrl, lastUpdated, currentSlug, jsonLd } = Astro.props;

const currentPath = `/docs/${currentSlug}`;
const flat = flattenNav();
const currentIndex = flat.findIndex((item) => item.href === currentPath);
const prev = currentIndex > 0 ? flat[currentIndex - 1] : null;
const next = currentIndex < flat.length - 1 ? flat[currentIndex + 1] : null;
const current = currentIndex >= 0 ? flat[currentIndex] : null;
---

<Base title={`${title} — Forge Docs`} description={description} layout="docs" jsonLd={jsonLd}>
  <div class="flex min-h-[calc(100vh-4rem)]">
    <!-- Left sidebar -->
    <DocsSidebar currentPath={currentPath} />

    <!-- Center content -->
    <div class="flex-1 lg:ml-[280px] xl:mr-[240px]">
      <div class="mx-auto max-w-3xl px-6 py-10 sm:px-8">
        {current && (
          <Breadcrumbs section={current.section} page={current.label} />
        )}

        <article class="prose max-w-none" data-pagefind-body>
          <slot />
        </article>

        <!-- Edit link -->
        {editUrl && (
          <div class="mt-8 pt-4 border-t border-dark-border">
            <a
              href={editUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-forge-orange transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
              </svg>
              Edit this page on GitHub
            </a>
          </div>
        )}

        <PrevNextNav prev={prev} next={next} />
      </div>
    </div>

    <!-- Right TOC -->
    <TableOfContents headings={headings} />
  </div>

  <CopyCodeButton />
</Base>
