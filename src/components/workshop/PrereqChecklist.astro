---
interface Props {
  attendee: string[];
  organizer: string[];
}
const { attendee, organizer } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-6">
  <div class="bg-dark-surface border border-dark-border rounded-forge-lg p-5">
    <h3 class="text-sm font-semibold text-heading mb-3 uppercase tracking-wide">Attendee brings</h3>
    <ul class="space-y-2">
      {attendee.map((item) => (
        <li class="flex items-start gap-2 text-sm text-secondary">
          <svg class="w-4 h-4 mt-0.5 shrink-0 text-forge-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span set:html={item}></span>
        </li>
      ))}
    </ul>
  </div>
  <div class="bg-dark-surface border border-dark-border rounded-forge-lg p-5">
    <h3 class="text-sm font-semibold text-heading mb-3 uppercase tracking-wide">Organizer provides</h3>
    <ul class="space-y-2">
      {organizer.map((item) => (
        <li class="flex items-start gap-2 text-sm text-secondary">
          <svg class="w-4 h-4 mt-0.5 shrink-0 text-forge-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span set:html={item}></span>
        </li>
      ))}
    </ul>
  </div>
</div>
