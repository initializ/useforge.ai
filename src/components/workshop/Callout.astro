---
interface Props {
  variant?: 'note' | 'warning' | 'security';
  label?: string;
}
const { variant = 'note', label } = Astro.props;

const variants = {
  note: {
    border: 'border-l-blue-400',
    bg: 'bg-blue-500/5',
    iconColor: 'text-blue-400',
    defaultLabel: 'Note',
  },
  warning: {
    border: 'border-l-amber-400',
    bg: 'bg-amber-500/5',
    iconColor: 'text-amber-400',
    defaultLabel: 'Warning',
  },
  security: {
    border: 'border-l-forge-orange',
    bg: 'bg-forge-orange/5',
    iconColor: 'text-forge-orange',
    defaultLabel: 'Security primitive',
  },
};
const v = variants[variant];
const shownLabel = label ?? v.defaultLabel;
---

<aside
  class={`my-4 rounded-forge-md border border-dark-border border-l-4 ${v.border} ${v.bg} p-4`}
  role="note"
>
  <div class="flex items-start gap-3">
    <span class={`${v.iconColor} mt-0.5 shrink-0`} aria-hidden="true">
      {variant === 'security' ? (
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-7a2 2 0 00-2-2H6a2 2 0 00-2 2v7a2 2 0 002 2zm10-12V7a4 4 0 00-8 0v4h8z" />
        </svg>
      ) : variant === 'warning' ? (
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      ) : (
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      )}
    </span>
    <div class="flex-1 min-w-0">
      <div class={`text-xs font-semibold uppercase tracking-wide ${v.iconColor} mb-1`}>
        {shownLabel}
      </div>
      <div class="text-sm text-secondary leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</aside>
