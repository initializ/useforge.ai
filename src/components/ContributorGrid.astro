---
import fs from 'node:fs';
import path from 'node:path';

interface Contributor {
  login: string;
  avatar_url: string;
  html_url: string;
}

let contributors: Contributor[] = [];
try {
  const filePath = path.resolve('src/data/contributors.json');
  if (fs.existsSync(filePath)) {
    const data = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    if (Array.isArray(data)) {
      contributors = data;
    } else if (data?.contributors) {
      contributors = data.contributors;
    }
  }
} catch {
  // contributors.json doesn't exist yet
}
---

<section class="py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-heading mb-4">
      Join the community
    </h2>
    <p class="text-secondary mb-10 max-w-xl mx-auto">
      Forge is open source and built by the community. Every contribution matters.
    </p>

    {contributors.length > 0 ? (
      <>
        <div class="flex flex-wrap justify-center gap-3 mb-6">
          {contributors.slice(0, 30).map(c => (
            <a
              href={c.html_url}
              target="_blank"
              rel="noopener"
              title={c.login}
              class="block"
            >
              <img
                src={c.avatar_url}
                alt={c.login}
                class="w-10 h-10 rounded-full border-2 border-dark-border hover:border-forge-orange transition-colors"
                loading="lazy"
              />
            </a>
          ))}
        </div>
        <p class="text-sm text-muted mb-6">
          {contributors.length} contributor{contributors.length !== 1 ? 's' : ''} and counting
        </p>
      </>
    ) : (
      <div class="bg-dark-surface border border-dark-border rounded-forge-lg p-8 max-w-md mx-auto mb-6">
        <p class="text-secondary mb-2">Be the first contributor</p>
        <p class="text-sm text-muted">
          Forge is just getting started. Help shape the future of agent development.
        </p>
      </div>
    )}

    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="https://go.useforge.ai/github"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 border border-dark-border hover:border-gray-500 text-body hover:text-heading rounded-forge-md transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        Contribute on GitHub
      </a>
      <a
        href="https://discord.gg/PtFa4z97Ag"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 border border-dark-border hover:border-gray-500 text-body hover:text-heading rounded-forge-md transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z" />
        </svg>
        Join Discord
      </a>
    </div>
  </div>
</section>
