---
const layers = [
  {
    label: 'Agent Skills',
    description: 'SKILL.md files — declarative agent capabilities',
    accent: 'border-forge-orange bg-forge-orange/5 text-forge-orange',
    arrow: true,
  },
  {
    label: 'Forge Runtime',
    description: 'Secure execution engine with sandboxing & egress control',
    accent: 'border-forge-amber bg-forge-amber/10 text-forge-amber',
    arrow: true,
  },
  {
    label: 'Infrastructure',
    description: 'Laptop · Docker · Kubernetes — runs anywhere',
    accent: 'border-dark-border bg-dark-surface text-gray-400',
    arrow: false,
  },
];
---

<section class="py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4">
    <h2 class="text-center text-3xl sm:text-4xl font-bold text-white mb-4">
      How Forge fits together
    </h2>
    <p class="text-center text-gray-400 mb-12 max-w-xl mx-auto">
      Three layers, one command. Forge sits between your skill definitions and the infrastructure, handling security and execution.
    </p>

    <div class="mx-auto max-w-lg flex flex-col items-center gap-3">
      {layers.map((layer, i) => (
        <>
          <div class={`w-full border rounded-forge-md p-5 text-center ${layer.accent}`}>
            <div class="font-semibold text-lg">{layer.label}</div>
            <div class="text-sm opacity-75 mt-1">{layer.description}</div>
          </div>
          {layer.arrow && (
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M12 5v14M19 12l-7 7-7-7" />
            </svg>
          )}
        </>
      ))}
    </div>
  </div>
</section>
