---
const categories = [
  {
    title: 'Infrastructure & DevOps',
    items: [
      'Kubernetes incident triage',
      'Log analysis agents',
      'Security alert automation',
    ],
  },
  {
    title: 'Engineering Workflows',
    items: [
      'GitHub issue classification',
      'Pull request summarization',
      'CI/CD validation agents',
    ],
  },
  {
    title: 'Enterprise Automation',
    items: [
      'Slack workflow agents',
      'Scheduled cron agents',
      'Cross-system orchestration',
    ],
  },
  {
    title: 'Agent-to-Agent (A2A)',
    items: [
      'Composable enterprise agents',
      'Workflow-driven AI execution',
      'Structured skill invocation',
    ],
  },
];
---

<section class="py-20 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-heading mb-4">
        Common Use Cases
      </h2>
      <p class="text-secondary text-lg max-w-xl mx-auto">
        Forge enables secure AI agents across your organization.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {categories.map(cat => (
        <div class="bg-dark-surface border border-dark-border rounded-forge-xl p-6">
          <h3 class="text-base font-bold text-heading mb-4">{cat.title}</h3>
          <ul class="space-y-2">
            {cat.items.map(item => (
              <li class="text-sm text-secondary flex items-start gap-2">
                <span class="text-forge-orange/60 mt-0.5 flex-shrink-0">·</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
