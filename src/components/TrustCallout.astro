<section class="py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mx-auto max-w-3xl bg-dark-surface border border-dark-border border-l-4 border-l-forge-orange rounded-forge-lg p-8 sm:p-10">
      <div class="flex items-start gap-4">
        <!-- Shield icon -->
        <div class="hidden sm:flex shrink-0 mt-1 text-forge-orange">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-white mb-3">Built for Enterprise Trust</h2>
          <p class="text-gray-400 leading-relaxed mb-6">
            Security isn't an afterthought — it's the foundation. Forge enforces egress allowlists so agents can only reach approved endpoints. There are no inbound tunnels or hidden network access. Every release is signed and reproducible, giving your security team full auditability.
          </p>
          <a
            href="/trust"
            class="inline-flex items-center gap-2 text-forge-orange hover:text-forge-amber font-medium transition-colors"
          >
            Learn about our security model &rarr;
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
