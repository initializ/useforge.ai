---
interface Props {
  prev: { label: string; href: string } | null;
  next: { label: string; href: string } | null;
}

const { prev, next } = Astro.props;
---

<nav class="flex items-stretch gap-4 mt-12 pt-8 border-t border-dark-border">
  {prev ? (
    <a
      href={prev.href}
      class="flex-1 flex items-center gap-3 p-4 bg-dark-surface border border-dark-border rounded-forge-md hover:border-forge-orange transition-colors group"
    >
      <svg class="w-4 h-4 text-gray-500 group-hover:text-forge-orange transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path d="m15 18-6-6 6-6" />
      </svg>
      <div>
        <span class="text-xs text-gray-500">Previous</span>
        <p class="text-sm text-gray-300 group-hover:text-white transition-colors">{prev.label}</p>
      </div>
    </a>
  ) : (
    <div class="flex-1" />
  )}

  {next ? (
    <a
      href={next.href}
      class="flex-1 flex items-center justify-end gap-3 p-4 bg-dark-surface border border-dark-border rounded-forge-md hover:border-forge-orange transition-colors group text-right"
    >
      <div>
        <span class="text-xs text-gray-500">Next</span>
        <p class="text-sm text-gray-300 group-hover:text-white transition-colors">{next.label}</p>
      </div>
      <svg class="w-4 h-4 text-gray-500 group-hover:text-forge-orange transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path d="m9 18 6-6-6-6" />
      </svg>
    </a>
  ) : (
    <div class="flex-1" />
  )}
</nav>
