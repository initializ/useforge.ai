---
interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 0 && (
  <nav
    id="toc"
    class="hidden xl:block fixed top-[4rem] right-0 w-[240px] h-[calc(100vh-4rem)] overflow-y-auto py-8 px-4"
  >
    <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">On this page</p>
    <ul class="space-y-1">
      {filtered.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            data-toc-link
            data-heading-slug={heading.slug}
            class:list={[
              'block text-sm transition-colors border-l-2 border-transparent hover:text-heading hover:border-gray-500',
              heading.depth === 3 ? 'pl-6 text-muted' : 'pl-3 text-secondary',
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  const tocLinks = document.querySelectorAll('[data-toc-link]');
  if (tocLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const slug = entry.target.id;
            tocLinks.forEach((link) => {
              const linkSlug = (link as HTMLElement).dataset.headingSlug;
              if (linkSlug === slug) {
                link.classList.add('text-forge-orange', 'border-forge-orange');
                link.classList.remove('text-secondary', 'text-muted', 'border-transparent');
              } else {
                link.classList.remove('text-forge-orange', 'border-forge-orange');
                const depth = link.classList.contains('pl-6') ? 'text-muted' : 'text-secondary';
                link.classList.add(depth, 'border-transparent');
              }
            });
          }
        }
      },
      { rootMargin: '-80px 0px -80% 0px' }
    );

    document.querySelectorAll('article h2[id], article h3[id]').forEach((el) => {
      observer.observe(el);
    });
  }
</script>
