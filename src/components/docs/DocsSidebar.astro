---
import { docsSidebar } from '@/data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<!-- Mobile sidebar toggle -->
<button
  type="button"
  id="sidebar-toggle"
  class="fixed top-20 left-4 z-50 p-2 bg-dark-surface border border-dark-border rounded-forge-md text-gray-400 hover:text-white transition-colors lg:hidden"
  aria-label="Toggle sidebar"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
    <path d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<!-- Sidebar backdrop (mobile) -->
<div id="sidebar-backdrop" class="fixed inset-0 z-30 bg-black/50 hidden lg:hidden"></div>

<!-- Sidebar -->
<aside
  id="docs-sidebar"
  class="fixed inset-y-0 left-0 z-40 w-[280px] bg-dark-bg border-r border-dark-border overflow-y-auto pt-20 pb-8 px-4 -translate-x-full lg:translate-x-0 transition-transform duration-200"
>
  <nav class="space-y-1">
    {docsSidebar.map((section) => {
      const isOpen = section.items?.some(item => currentPath === item.href) ||
                     currentPath === section.href;

      return section.items ? (
        <details open={isOpen} class="group">
          <summary class="flex items-center justify-between px-3 py-2 text-sm font-semibold text-gray-300 hover:text-white cursor-pointer select-none list-none">
            <span>{section.label}</span>
            <svg class="w-4 h-4 text-gray-500 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="m9 18 6-6-6-6" />
            </svg>
          </summary>
          <ul class="mt-1 ml-2 space-y-0.5">
            {section.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'block px-3 py-1.5 text-sm rounded-forge-sm transition-colors',
                    currentPath === item.href
                      ? 'border-l-2 border-forge-orange text-forge-orange bg-forge-orange/5 font-medium'
                      : 'text-gray-400 hover:text-white hover:bg-dark-hover border-l-2 border-transparent',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </details>
      ) : (
        <a
          href={section.href}
          class:list={[
            'block px-3 py-2 text-sm font-semibold rounded-forge-sm transition-colors',
            currentPath === section.href
              ? 'border-l-2 border-forge-orange text-forge-orange bg-forge-orange/5'
              : 'text-gray-300 hover:text-white hover:bg-dark-hover border-l-2 border-transparent',
          ]}
        >
          {section.label}
        </a>
      );
    })}
  </nav>
</aside>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('docs-sidebar');
  const backdrop = document.getElementById('sidebar-backdrop');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    backdrop?.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    backdrop?.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  toggle?.addEventListener('click', () => {
    const isHidden = sidebar?.classList.contains('-translate-x-full');
    if (isHidden) {
      openSidebar();
    } else {
      closeSidebar();
    }
  });

  backdrop?.addEventListener('click', closeSidebar);
</script>
