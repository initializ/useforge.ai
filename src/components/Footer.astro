---
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Docs', href: '/docs' },
      { label: 'Hub', href: '/hub' },
      { label: 'Changelog', href: '/changelog' },
      { label: 'Compare', href: '/compare' },
      { label: 'Trust', href: '/trust' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Blog', href: '/blog' },
      { label: 'Getting Started', href: '/docs/getting-started/installation' },
      { label: 'SKILL.md Spec', href: '/docs/skills' },
    ],
  },
  {
    title: 'Community',
    links: [
      { label: 'GitHub', href: 'https://github.com/initializ/forge', external: true },
      { label: 'Discord', href: 'https://discord.gg/initializ', external: true },
      { label: 'Twitter', href: 'https://twitter.com/initializ', external: true },
      { label: 'About', href: '/about' },
    ],
  },
];
---

<footer class="border-t border-dark-border bg-dark-bg">
  <div class="mx-auto max-w-7xl px-4 py-12">
    <!-- Link columns -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-8 mb-12">
      {columns.map(col => (
        <div>
          <h3 class="text-sm font-semibold text-heading mb-4">{col.title}</h3>
          <ul class="space-y-2">
            {col.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-secondary hover:text-heading transition-colors"
                  {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {link.label}
                  {link.external && (
                    <svg class="inline-block w-3 h-3 ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-dark-border pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <img src="/logos/forge-monogram-light.svg" alt="Forge" class="h-6 w-6 opacity-50 dark:hidden" />
        <img src="/logos/forge-monogram.svg" alt="Forge" class="h-6 w-6 opacity-50 hidden dark:block" />
        <span class="text-sm text-muted">
          Built by <a href="https://initializ.ai" target="_blank" rel="noopener" class="hover:text-secondary transition-colors">initializ</a> &middot; MIT License &middot; &copy; {year}
        </span>
      </div>
      <a
        href="https://github.com/initializ/forge/actions"
        target="_blank"
        rel="noopener"
        class="text-xs text-muted hover:text-secondary transition-colors"
      >
        CI Status
      </a>
    </div>
  </div>
</footer>
