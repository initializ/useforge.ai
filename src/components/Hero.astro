---

---

<section class="relative overflow-hidden py-24 sm:py-32">
  <!-- Radial orange glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-forge-orange/10 rounded-full blur-[128px] pointer-events-none"></div>

  <div class="relative mx-auto max-w-7xl px-4 text-center">
    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white mb-6">
      <span class="bg-gradient-to-r from-forge-orange to-forge-amber bg-clip-text text-transparent">SKILL.md</span>
      &rarr; Agent
    </h1>

    <!-- Subtitle -->
    <p class="mx-auto max-w-2xl text-lg sm:text-xl text-gray-400 mb-10">
      Define agent skills in Markdown. Forge compiles them into secure, sandboxed agents that run anywhere — your laptop, Docker, or Kubernetes.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href="/docs/getting-started/installation"
        class="inline-flex items-center gap-2 px-6 py-3 bg-forge-orange hover:bg-forge-deep text-white font-semibold rounded-forge-md transition-colors"
      >
        Get Started &rarr;
      </a>
      <a
        href="https://github.com/initializ/forge"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 border border-dark-border hover:border-gray-500 text-gray-300 hover:text-white rounded-forge-md transition-colors"
      >
        View on GitHub
      </a>
    </div>

    <!-- Install command pill -->
    <div class="inline-flex items-center gap-3 px-4 py-2 bg-dark-surface border border-dark-border rounded-full text-sm">
      <code class="font-mono text-spark-mid">brew install initializ/tap/forge</code>
      <button
        type="button"
        id="copy-install"
        class="p-1 text-gray-500 hover:text-white transition-colors"
        aria-label="Copy install command"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
          <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
        </svg>
      </button>
    </div>

    <!-- Terminal demo -->
    <div class="mt-12 mx-auto max-w-2xl text-left">
      <div class="bg-dark-surface border border-dark-border rounded-forge-lg overflow-hidden">
        <!-- Terminal header -->
        <div class="flex items-center gap-2 px-4 py-3 border-b border-dark-border">
          <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
          <span class="ml-2 text-xs text-gray-500 font-mono">terminal</span>
        </div>
        <!-- Terminal body -->
        <div class="p-4 font-mono text-sm leading-relaxed">
          <p><span class="text-forge-orange">$</span> <span class="text-white">forge init my-agent</span></p>
          <p class="text-gray-500">Creating agent scaffold...</p>
          <p class="text-green-400">&#10003; Generated SKILL.md</p>
          <p class="text-green-400">&#10003; Created agent directory</p>
          <p class="mt-3"><span class="text-forge-orange">$</span> <span class="text-white">forge run</span></p>
          <p class="text-gray-500">Compiling skills...</p>
          <p class="text-green-400">&#10003; Agent running on localhost:8080</p>
          <p class="text-spark-mid mt-1">Ready — 3 skills loaded, egress locked</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const copyBtn = document.getElementById('copy-install');
  copyBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText('brew install initializ/tap/forge').then(() => {
      copyBtn.innerHTML = `<svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M20 6L9 17l-5-5" /></svg>`;
      setTimeout(() => {
        copyBtn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" /></svg>`;
      }, 2000);
    });
  });
</script>
