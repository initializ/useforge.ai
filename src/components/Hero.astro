---
// Hero component — homepage above-the-fold
---

<section class="relative overflow-hidden pt-16 pb-24 sm:pt-24 sm:pb-32">
  <!-- Radial orange glow behind text -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full opacity-5 dark:opacity-15 blur-3xl pointer-events-none"
    style="background: radial-gradient(ellipse, #F97316, transparent 70%);"
  ></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- H1 -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6 leading-tight">
      <span class="bg-gradient-to-br from-forge-amber via-forge-orange to-forge-deep bg-clip-text text-transparent">
        Secure, Portable AI Agent Runtime
      </span>
      <br />
      <span class="text-heading">for Enterprise Work</span>
    </h1>

    <!-- Subheading -->
    <p class="text-lg sm:text-xl text-secondary max-w-2xl mx-auto mb-6 leading-relaxed">
      Forge is the open-source runtime for Anthropic's Agent Skills standard — built for the agent that runs next to a service, in your environment, on infrastructure you already operate. Write a SKILL.md. Compile to a portable, hardened agent. Deploy it anywhere containers run: Kubernetes, on-prem, air-gapped, embedded in CI, or as an A2A endpoint.
    </p>

    <!-- Trust strip -->
    <p class="text-xs sm:text-sm text-muted max-w-3xl mx-auto mb-10">
      Built on Anthropic's open Agent Skills standard · Apache 2.0 licensed · Single static binary · No managed-service dependency
    </p>

    <!-- CTAs — Primary: Get started, Secondary: Compare Forge -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href="/docs/getting-started/installation"
        class="inline-flex items-center gap-2 px-6 py-3 bg-forge-orange hover:bg-forge-deep text-white font-medium rounded-forge-md transition-all duration-300 ease-forge shadow-lg shadow-forge-orange/20 hover:shadow-forge-orange/30"
      >
        Get started
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a
        href="/compare/"
        class="inline-flex items-center gap-2 px-6 py-3 border border-dark-border text-body hover:text-heading hover:border-gray-500 font-medium rounded-forge-md transition-all duration-300 ease-forge"
      >
        Compare Forge
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <!-- Install command pill -->
    <div class="inline-flex items-center gap-3 px-5 py-3 bg-dark-surface border border-dark-border rounded-forge-lg font-mono text-sm text-body">
      <span class="text-muted select-none">$</span>
      <code>brew install initializ/tap/forge</code>
      <button
        class="copy-btn p-1 text-muted hover:text-forge-orange transition-colors duration-150"
        data-copy="brew install initializ/tap/forge"
        aria-label="Copy install command"
      >
        <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <svg class="w-4 h-4 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>
      </button>
    </div>

    <!-- Terminal demo (always dark-themed) -->
    <div class="mt-16 max-w-3xl mx-auto" data-terminal>
      <div class="bg-[#111827] border border-[#1F2937] rounded-forge-xl overflow-hidden shadow-2xl">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-[#1F2937]">
          <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
          <span class="ml-2 text-xs font-mono text-[#6b7280]">forge — terminal</span>
        </div>
        <div class="p-6 font-mono text-sm leading-relaxed text-[#d1d5db] min-h-[200px]">
          <div class="text-[#6b7280]">$ forge init</div>
          <div class="mt-2 text-forge-orange">&#9889; Forge — Agent Initializer</div>
          <div class="mt-1 text-[#9ca3af]">  Agent name: <span class="text-[#e5e7eb]">my-agent</span></div>
          <div class="text-[#9ca3af]">  Provider: <span class="text-[#e5e7eb]">openai (gpt-4o)</span></div>
          <div class="text-[#9ca3af]">  Skills: <span class="text-[#e5e7eb]">summarize, weather</span></div>
          <div class="text-[#9ca3af]">  Egress: <span class="text-[#e5e7eb]">api.openai.com, wttr.in</span></div>
          <div class="mt-2 text-green-400">&#10003; Agent created — forge.yaml, SKILL.md, .env</div>
          <div class="mt-4 text-[#6b7280]">$ forge run</div>
          <div class="mt-1 text-forge-amber">&#128296; Forge v0.5.0 — agent running on :8080</div>
          <div class="text-[#9ca3af]">  Egress: allowlist (4 domains)</div>
          <div class="text-[#9ca3af]">  Tools: http_request, json_parse, cli_execute</div>
          <div class="text-[#9ca3af]">  Memory: session (persistent) + long-term</div>
          <div class="mt-2 text-[#6b7280]">Ready. Type a message or Ctrl+C to quit.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      if (!text) return;
      await navigator.clipboard.writeText(text);
      const copyIcon = btn.querySelector('.copy-icon');
      const checkIcon = btn.querySelector('.check-icon');
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
      }, 2000);
    });
  });
</script>
