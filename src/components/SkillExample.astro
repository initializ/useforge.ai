---
const skillSource = `---
name: code-review
description: AI-powered code review for diffs and PRs
category: developer
tags:
  - code-review
  - security
  - pull-request
bins:
  - curl
  - jq
  - git
env:
  one_of:
    - ANTHROPIC_API_KEY
    - OPENAI_API_KEY
egress:
  - api.anthropic.com
  - api.openai.com
---

# Code Review

AI-powered code review that analyzes diffs
for bugs, security issues, and improvements.

## Constraints
- Read-only analysis, never modifies code
- Structured JSON output with severity levels
- Supports local diffs and GitHub PRs`;

const outputLines = [
  { key: 'name', value: 'code-review' },
  { key: 'description', value: 'AI-powered code review for diffs and PRs' },
  { key: 'category', value: 'developer' },
  { key: 'tools', value: 'code_review_diff, code_review_file' },
  { key: 'egress', value: 'api.anthropic.com, api.openai.com' },
  { key: 'status', value: 'ready', highlight: true },
];
---

<section class="py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4">
    <h2 class="text-center text-3xl sm:text-4xl font-bold text-heading mb-4">
      Skills are just Markdown
    </h2>
    <p class="text-center text-secondary mb-12 max-w-xl mx-auto">
      Define everything in a single SKILL.md file — model, tools, egress rules, and prompt. Forge handles the rest.
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mx-auto max-w-5xl">
      <!-- Left: SKILL.md source -->
      <div class="bg-dark-surface border border-dark-border rounded-forge-lg overflow-hidden">
        <div class="px-4 py-2 border-b border-dark-border flex items-center gap-2">
          <span class="text-xs font-mono text-muted">SKILL.md</span>
        </div>
        <pre class="p-4 text-sm font-mono text-body leading-relaxed overflow-x-auto"><code>{skillSource}</code></pre>
      </div>

      <!-- Right: Compiled output -->
      <div class="bg-dark-surface border border-dark-border rounded-forge-lg overflow-hidden">
        <div class="px-4 py-2 border-b border-dark-border flex items-center gap-2">
          <span class="text-xs font-mono text-muted">forge inspect</span>
        </div>
        <div class="p-4 font-mono text-sm space-y-2">
          {outputLines.map(line => (
            <div class="flex gap-3">
              <span class="text-muted min-w-[100px]">{line.key}:</span>
              <span class:list={[line.highlight ? 'text-green-400' : 'text-spark-mid']}>
                {line.value}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
